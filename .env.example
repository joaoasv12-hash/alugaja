# ─── Banco de dados PostgreSQL ───────────────────────────────────────────────
# Neon: https://neon.tech  |  Supabase: https://supabase.com
DATABASE_URL="postgresql://usuario:senha@host:5432/alugaja?sslmode=require"

# ─── NextAuth ─────────────────────────────────────────────────────────────────
# Gere o secret: openssl rand -base64 32
NEXTAUTH_URL="https://seu-dominio.vercel.app"
NEXTAUTH_SECRET="seu-segredo-super-secreto-aqui"

# ─── OAuth Google ─────────────────────────────────────────────────────────────
# console.cloud.google.com → APIs → Credenciais → OAuth 2.0
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── E-mail SMTP ──────────────────────────────────────────────────────────────
# Gmail: ative "Senha de app" em myaccount.google.com/security
# Resend: https://resend.com  (SMTP_HOST=smtp.resend.com, SMTP_PORT=465)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="seu@gmail.com"
SMTP_PASS="sua-senha-de-app-16-digitos"
SMTP_FROM="AlugaJá <noreply@alugaja.com.br>"

# ─── Armazenamento de imagens ─────────────────────────────────────────────────
# Cloudinary: https://cloudinary.com (free tier: 25 GB)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# ─── Mercado Pago ─────────────────────────────────────────────────────────────
# Sandbox: https://developers.mercadopago.com
MERCADOPAGO_ACCESS_TOKEN=""
MERCADOPAGO_PUBLIC_KEY=""
MERCADOPAGO_WEBHOOK_SECRET=""

# ─── Admin ────────────────────────────────────────────────────────────────────
# Apenas este e-mail recebe papel SUPER_ADMIN automaticamente
SUPER_ADMIN_EMAIL="m60345876@gmail.com"
